+def _maybe_route_turn(agent, user_message: str) -> None:
+    """In-process per-turn router (TUI/CLI/oneshot).
+
+    Ask any registered ``model_request`` middleware for a route and apply it with
+    a live ``switch_model`` BEFORE the first API call of the turn. No-op when no
+    middleware is registered. When the route carries a per-tier ``fallback`` list
+    it replaces the turn's ``_fallback_chain`` (tier-aware fallback); otherwise the
+    config (global) chain is restored. ``switch_model`` preserves the chain object,
+    so an out-of-credits routed model still falls back. Fail-open: any error keeps
+    the current model.
+    """
+    try:
+        from hermes_cli.plugins import has_middleware
+        if not has_middleware("model_request"):
+            return
+        from hermes_cli.middleware import apply_model_request_middleware
+
+        # Snapshot the config (global) fallback chain once — before we ever swap
+        # it for a per-tier chain — so non-tier turns can restore it.
+        if not hasattr(agent, "_router_global_fallback"):
+            agent._router_global_fallback = list(getattr(agent, "_fallback_chain", []) or [])
+
+        res = apply_model_request_middleware(
+            {
+                "model": agent.model,
+                "provider": agent.provider,
+                "base_url": getattr(agent, "base_url", None),
+                "api_mode": getattr(agent, "api_mode", None),
+            },
+            user_message=user_message or "",
+            explicit_model=bool(getattr(agent, "_model_pinned", False)),
+        )
+
+        tier_fallback = None
+        if res.changed and isinstance(res.payload, dict):
+            sel = res.payload
+            new_model = sel.get("model") or agent.model
+            new_provider = sel.get("provider") or agent.provider
+            tier_fallback = sel.get("fallback")
+
+            if new_model != agent.model or new_provider != agent.provider:
+                from hermes_cli.runtime_provider import resolve_runtime_provider
+                rp = resolve_runtime_provider(requested=new_provider, target_model=new_model)
+                if not (rp.get("api_key") or rp.get("command")):
+                    logger.warning(
+                        "model-router: no credentials for %s; keeping %s/%s",
+                        new_provider, agent.provider, agent.model,
+                    )
+                else:
+                    agent.switch_model(
+                        new_model=new_model,
+                        new_provider=new_provider,
+                        api_key=rp.get("api_key", "") or "",
+                        base_url=rp.get("base_url", "") or "",
+                        api_mode=rp.get("api_mode", "") or "",
+                    )
+                    logger.info("model-router: turn routed -> %s/%s", new_provider, new_model)
+
+        # Tier-aware fallback: apply the per-tier chain when present, else restore
+        # the global chain — keeps a cheap turn cheap on failure rather than
+        # escalating up the global chain.
+        new_chain = list(tier_fallback) if tier_fallback else list(agent._router_global_fallback)
+        if list(getattr(agent, "_fallback_chain", []) or []) != new_chain:
+            agent._fallback_chain = new_chain
+            agent._fallback_index = 0
+            agent._fallback_model = new_chain[0] if new_chain else None
+            if tier_fallback:
+                logger.info("model-router: tier fallback chain (%d entries) applied", len(new_chain))
+    except Exception as exc:  # never break the turn
+        logger.warning("model-router in-process routing skipped: %s", exc)
+
+
