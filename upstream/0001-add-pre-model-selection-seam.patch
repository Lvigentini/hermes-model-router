+    def _apply_model_selection(self, user_message: str, model: str, runtime: dict) -> tuple[str, dict]:
+        """Run ``model_request`` middleware and apply any re-route.
+
+        Returns ``(model, runtime)`` — unchanged when no middleware is
+        registered or the route is left as-is. On a cross-provider re-route the
+        chosen provider's credentials are resolved via ``resolve_runtime_provider``
+        so the turn is bound to the right account. Always fail-open: any error
+        keeps the session's primary route.
+        """
+        try:
+            from hermes_cli.middleware import apply_model_request_middleware
+            result = apply_model_request_middleware(
+                {
+                    "model": model,
+                    "provider": runtime.get("provider"),
+                    "base_url": runtime.get("base_url"),
+                    "api_mode": runtime.get("api_mode"),
+                },
+                user_message=user_message or "",
+            )
+        except Exception:
+            logger.debug("model_request middleware raised; keeping primary route", exc_info=True)
+            return model, runtime
+
+        if not result.changed or not isinstance(result.payload, dict):
+            return model, runtime
+
+        sel = result.payload
+        new_model = sel.get("model") or model
+        cur_provider = runtime.get("provider")
+        new_provider = sel.get("provider") or cur_provider
+
+        if new_provider and new_provider != cur_provider:
+            try:
+                from hermes_cli.runtime_provider import resolve_runtime_provider
+                rp = resolve_runtime_provider(requested=new_provider, target_model=new_model)
+            except Exception:
+                logger.warning(
+                    "model_request: cannot resolve credentials for provider %s; "
+                    "keeping primary route", new_provider, exc_info=True,
+                )
+                return model, runtime
+            if not (rp.get("api_key") or rp.get("command")):
+                logger.warning(
+                    "model_request: provider %s has no usable credentials; keeping primary route",
+                    new_provider,
+                )
+                return model, runtime
+            logger.info(
+                "model_request: re-routed turn %s/%s -> %s/%s",
+                cur_provider, model, new_provider, new_model,
+            )
+            return new_model, {
+                "api_key": rp.get("api_key"),
+                "base_url": rp.get("base_url") or sel.get("base_url"),
+                "provider": new_provider,
+                "api_mode": rp.get("api_mode") or sel.get("api_mode"),
+                "command": rp.get("command"),
+                "args": list(rp.get("args") or []),
+                "credential_pool": rp.get("credential_pool"),
+                "max_tokens": runtime.get("max_tokens"),
+            }
+
+        if new_model != model:
+            logger.info(
+                "model_request: re-routed model %s -> %s (provider %s)",
+                model, new_model, cur_provider,
+            )
+        return new_model, runtime
+
